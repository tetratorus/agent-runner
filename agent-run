    },
}

SCRIPT_DIR = Path(__file__).parent.resolve()
DOCKER_DIR = SCRIPT_DIR / "docker"
WALLET_BOOTSTRAP = DOCKER_DIR / "wallet-bootstrap.sh"


# ─── Helpers ─────────────────────────────────────────────────────────────────

def log(msg):
    print(f"[agent-run] {msg}", file=sys.stderr)


def run_cmd(cmd, cwd=None, capture=False):
    """Run a shell command. Returns (rc, stdout, stderr)."""
    if isinstance(cmd, list):
        cmd = " ".join(cmd)
    if not capture:
        rc = subprocess.call(cmd, shell=True, cwd=cwd)
        return rc, "", ""
    r = subprocess.run(cmd, shell=True, cwd=cwd, capture_output=True, text=True)
    return r.returncode, r.stdout, r.stderr


def docker_available():
    rc, _, _ = run_cmd("docker info", capture=True)
    return rc == 0


def build_base_image():
    """Build the shared base image."""
    dockerfile = DOCKER_DIR / "Dockerfile.base"
    if not dockerfile.exists():
        log(f"ERROR: Base Dockerfile not found: {dockerfile}")
        return False
    log("Building base image...")
    cmd = (
        f"docker build --platform linux/amd64 "
        f"-t agent-runner/base -f {dockerfile} {DOCKER_DIR}"
    )
    rc, _, err = run_cmd(cmd, capture=True)
    if rc != 0:
        log(f"Base build failed:\n{err}")
        return False
    log("Base image ✓")
    return True


def build_image(agent_key):
    cfg = AGENTS[agent_key]
    dockerfile = DOCKER_DIR / cfg["dockerfile"]
    if not dockerfile.exists():
        log(f"ERROR: Dockerfile not found: {dockerfile}")
        return False

    log(f"Building {cfg['name']} image...")
    cmd = (
        f"docker build --platform linux/amd64 "
        f"-t {cfg['image']} -f {dockerfile} {DOCKER_DIR}"
    )
    rc, _, err = run_cmd(cmd, capture=True)
    if rc != 0:
        log(f"Build failed:\n{err}")
        return False
    log(f"Built {cfg['name']} ✓")
    return True


# Suffixes for env vars that are forwarded if set but never required —
# base URLs, custom hosts, provider/model selectors.
_OPTIONAL_ENV_SUFFIXES = ("_BASE_URL", "_HOST", "_MODEL", "_PROVIDER")


def check_env(agent_key):
    """Ensure required env vars are set. Base URLs and provider/model
    selectors are forwarded when set but never required."""
    cfg = AGENTS[agent_key]
    missing = []
    for var in cfg["env"]:
        if os.environ.get(var):
            continue
        if any(var.endswith(s) for s in _OPTIONAL_ENV_SUFFIXES):
            continue
        missing.append(var)
    if missing:
        log(f"ERROR: Missing env vars for {cfg['name']}: {', '.join(missing)}")
        log(f"  Set them: export {' '.join(f'{v}=...' for v in missing)}")
        return False
    return True


def run_agent(agent_key, prompt, workspace, out_dir=None, timeout=600):
    """Run a single agent in Docker."""
    cfg = AGENTS[agent_key]

    if not check_env(agent_key):
        return 1

    ws = Path(workspace).resolve()
    if not ws.exists():
        log(f"ERROR: Workspace not found: {ws}")
        return 1

    # Results directory
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    if out_dir:
        result_dir = Path(out_dir).resolve() / agent_key / ts
    else:
        result_dir = SCRIPT_DIR / "results" / agent_key / ts
    result_dir.mkdir(parents=True, exist_ok=True)

    # Write prompt to file (agents read it)
    prompt_file = result_dir / "prompt.txt"
    prompt_file.write_text(prompt)

    # Environment vars. If the mounted workspace has a .env file, pass it into
    # the container so prepared wallet workspaces can carry runtime secrets like
    # TWAK_WALLET_PASSWORD without committing them.
    env_parts = [f'-e {v}="${v}"' for v in cfg["env"] if os.environ.get(v)]
    env_file = ws / ".env"
    if env_file.exists():
        env_parts.append(f"--env-file {shlex.quote(str(env_file))}")
    env_args = " ".join(env_parts)

    # Output log
    log_file = result_dir / "output.log"

    log(f"Running {cfg['name']} on {ws.name}...")
    log(f"  Results: {result_dir}")

    cmd = (
        f"docker run --rm --platform linux/amd64 "
        f"--add-host=host.docker.internal:host-gateway "
        f"-v '{ws}:/workspace:rw' "
        f"-v '{result_dir}:/results:rw' "
        f"-v '{WALLET_BOOTSTRAP}:/usr/local/bin/wallet-bootstrap:ro' "
        f"{env_args} "
        f"-e PROMPT_FILE=/results/prompt.txt "
        f"-e WORKSPACE=/workspace "
        f"--name agent-{agent_key}-{ts} "
        f"--entrypoint /bin/bash "
        f"{cfg['image']} "
        f"-lc 'source /usr/local/bin/wallet-bootstrap && exec /usr/local/bin/run-agent'"
    )

    container_name = f"agent-{agent_key}-{ts}"
    timed_out = {"hit": False}

    def kill_container():
        timed_out["hit"] = True
        log(f"TIMEOUT after {timeout}s — killing {container_name}")
        run_cmd(f"docker kill {container_name}", capture=True)

    try:
        with open(log_file, "w") as lf:
            lf.write(f"# {cfg['name']} run started at {datetime.now().isoformat()}\n")
            lf.write(f"# Workspace: {ws}\n")
            lf.write(f"# Prompt:\n{prompt}\n")
            lf.write("#" * 60 + "\n\n")
            lf.flush()

            proc = subprocess.Popen(
                cmd, shell=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
            )
            # Watchdog: docker-kill the container if it overruns. We can't rely
            # on proc.wait(timeout=...) because the stdout drain loop below
            # blocks until the container has already exited.
            timer = threading.Timer(timeout, kill_container)
            timer.daemon = True
            timer.start()
            try:
                for line in proc.stdout:
                    lf.write(line)
                    lf.flush()
                    print(line, end="")
                proc.wait()
            finally:
                timer.cancel()
            rc = 124 if timed_out["hit"] else proc.returncode
            lf.write(f"\n# Exit code: {rc}\n")

        log(f"Finished {cfg['name']} — exit {rc}, log: {log_file}")
        return rc

    except KeyboardInterrupt:
        log("Interrupted — killing container")
        run_cmd(f"docker kill {container_name}", capture=True)
        return 130


# ─── CLI ─────────────────────────────────────────────────────────────────────

def cmd_setup(args):
    """Build all Docker images."""
    if not docker_available():
        log("ERROR: Docker not available. Install Docker Desktop for macOS.")
        return 1

    if not build_base_image():
        return 1

    ok = True
    for key in AGENTS:
        if not build_image(key):
            ok = False
    return 0 if ok else 1


def cmd_list(args):
    print("Available agents:\n")
    for key, cfg in AGENTS.items():
        env_status = " ".join(
            f"{'✓' if os.environ.get(v) else '✗'} {v}"
            for v in cfg["env"]
        )
        print(f"  {key:15s}  {cfg['name']:20s}  {cfg['description']}")
        print(f"                   env: {env_status}")
    print(f"\nRun: agent-run setup  # to build images")
    return 0


def cmd_run(args):
    if not docker_available():
        log("ERROR: Docker not available.")
        return 1

    agents = args.agent.split(",")
    agents = [a.strip() for a in agents]

    # Resolve aliases
    if "all" in agents:
        agents = list(AGENTS.keys())

    # Validate
    for a in agents:
        if a not in AGENTS:
            log(f"ERROR: Unknown agent: {a}")
            log(f"  Available: {', '.join(AGENTS.keys())}")
            return 1

    # Get prompt
    if args.prompt:
        prompt = args.prompt
    elif args.prompt_file:
        pf = Path(args.prompt_file)
        if not pf.exists():
            log(f"ERROR: Prompt file not found: {pf}")
            return 1
        prompt = pf.read_text()
    else:
        log("ERROR: Provide --prompt or --prompt-file")
        return 1

    if len(agents) == 1:
        return run_agent(agents[0], prompt, args.workspace, args.out, args.timeout)

    # Multi-agent: run concurrently
    log(f"Running {len(agents)} agents concurrently...")
    procs = []
    for a in agents:
        # Fork-ish: run in background
        cmd = [
            sys.executable, __file__, a,
            "--prompt", prompt,
            "--workspace", args.workspace,
        ]
        if args.out:
            cmd += ["--out", args.out]
        if args.timeout:
            cmd += ["--timeout", str(args.timeout)]

        log(f"  Spawning {a}...")
        p = subprocess.Popen(cmd)
        procs.append((a, p))

    # Wait for all
    results = {}
    for a, p in procs:
        rc = p.wait()
        results[a] = rc
        status = "✓" if rc == 0 else f"✗ ({rc})"
        log(f"  {a}: {status}")

    log("All agents finished.")
    for a, rc in results.items():
        print(f"  {a:15s} exit={rc}")
    return 0 if all(rc == 0 for rc in results.values()) else 1


def main():
    parser = argparse.ArgumentParser(
        description="Run coding agents in Docker containers",
        usage="agent-run <setup|list|agent> [options]",
    )
    parser.add_argument("command", help="'setup', 'list', an agent name, 'all', or comma-separated agents")
    parser.add_argument("--prompt", "-p", help="Prompt string")
    parser.add_argument("--prompt-file", "-f", help="Path to prompt file")
    parser.add_argument("--workspace", "-w", help="Project directory (required for agent runs)")
    parser.add_argument("--out", "-o", help="Results output directory")
    parser.add_argument("--timeout", "-t", type=int, default=600, help="Timeout in seconds")

    args = parser.parse_args()

    if args.command == "setup":
        return cmd_setup(args)
    if args.command == "list":
        return cmd_list(args)

    # Anything else is an agent name (or 'all', or comma-separated).
    if not args.workspace:
        log("ERROR: --workspace required for agent runs")
        return 1
    args.agent = args.command
    return cmd_run(args)


if __name__ == "__main__":
    sys.exit(main())

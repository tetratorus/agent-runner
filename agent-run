#!/usr/bin/env python3
"""
agent-run — spin up coding agents in Docker containers on macOS.

Usage:
  agent-run setup                          # Build all agent images
  agent-run list                           # List available agents
  agent-run <agent> --prompt "..." --workspace ./project
  agent-run <agent> --prompt-file ./prompt.md --workspace ./project
  agent-run all --prompt "..." --workspace ./project   # Run all agents
  agent-run claude-code,codex --prompt "..." --workspace ./project

Examples:
  agent-run claude-code --prompt "Fix the auth bug in login.py" --workspace ./my-app
  agent-run codex --prompt-file ./task.md --workspace ./my-app --out ./results
  agent-run all --prompt "Refactor utils.py to use async" --workspace ./my-app
"""

import argparse
import os
import subprocess
import sys
import threading
import time
import json
import shlex
from pathlib import Path
from datetime import datetime

# ─── Config ──────────────────────────────────────────────────────────────────

AGENTS = {

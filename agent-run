        "env": ["OPENAI_API_KEY", "OPENAI_BASE_URL"],
        "description": "OpenAI's Codex CLI — token-efficient, fast terminal",
    },
    "aider": {
        "name": "Aider",
        "dockerfile": "Dockerfile.aider",

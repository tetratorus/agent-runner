FROM agent-runner/base:latest

USER root

# Install Codex CLI
RUN npm install -g @openai/codex

# Create entrypoint script
RUN cat > /usr/local/bin/run-agent << 'SCRIPT'
#!/bin/bash
set -e
PROMPT=$(cat "$PROMPT_FILE")
echo "=== Codex CLI ==="
echo "Prompt: $PROMPT"
echo "Workspace: $WORKSPACE"
echo ""
cd "$WORKSPACE"
# Codex non-interactive mode (auto approval, quiet)
codex --approval-mode auto-qos "$PROMPT" 2>&1 || true
echo ""
echo "=== Done ==="
SCRIPT
RUN chmod +x /usr/local/bin/run-agent

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/run-agent"]

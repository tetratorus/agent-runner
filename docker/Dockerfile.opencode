FROM agent-runner/base:latest

USER root

# Install OpenCode
RUN npm install -g opencode-ai

# Create entrypoint script
RUN cat > /usr/local/bin/run-agent << 'SCRIPT'
#!/bin/bash
set -e
PROMPT=$(cat "$PROMPT_FILE")
echo "=== OpenCode ==="
echo "Prompt: $PROMPT"
echo "Workspace: $WORKSPACE"
echo ""
cd "$WORKSPACE"
# OpenCode non-interactive mode. --dangerously-skip-permissions auto-approves.
# Route via the anthropic provider (proxy at /claude/v1) — opencode's openai
# provider uses the Responses API which DeepSeek doesn't implement.
opencode run --dangerously-skip-permissions --format json --model "${OPENCODE_MODEL:-anthropic/claude-sonnet-4-5}" "$PROMPT" 2>&1 || true
echo ""
echo "=== Done ==="
SCRIPT
RUN chmod +x /usr/local/bin/run-agent

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/run-agent"]

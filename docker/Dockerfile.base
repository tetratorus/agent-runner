# Base image for coding agents
FROM --platform=linux/amd64 debian:bookworm-slim

# Install core tools
RUN apt-get update && apt-get install -y \
    curl ca-certificates git git-lfs \
    python3 python3-pip python3-venv \
    nodejs npm \
    build-essential \
    libnspr4 libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 \
    libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 \
    libxrandr2 libgbm1 libasound2 libgtk-3-0 libxshmfence1 \
    xvfb xauth dbus \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 (Debian's node is older)
RUN npm install -g n && n 20

# Create non-root user. Setup and runtime containers both default to this user,
# so workspace files written during setup are owned by — and readable by — the
# same uid at runtime. No host-uid matching needed.
RUN groupadd -g 1000 agent && \
    useradd -u 1000 -g 1000 -m -s /bin/bash agent

WORKDIR /workspace
USER agent

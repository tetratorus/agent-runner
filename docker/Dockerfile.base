# Base image for coding agents
FROM --platform=linux/amd64 debian:bookworm-slim

# Install core tools
RUN apt-get update && apt-get install -y \
    curl ca-certificates git git-lfs \
    python3 python3-pip python3-venv \
    nodejs npm \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 (Debian's node is older)
RUN npm install -g n && n 20

# Create non-root user (overridden at build time)
ARG USER_ID=1000
ARG GROUP_ID=1000
RUN groupadd -g ${GROUP_ID} agent && \
    useradd -u ${USER_ID} -g ${GROUP_ID} -m -s /bin/bash agent

WORKDIR /workspace
USER agent

FROM agent-runner/base:latest

USER root

# Install nanobot
RUN pip3 install --break-system-packages nanobot-ai

# Seed ~/.nanobot/config.json so nanobot's "custom" (OpenAI-compatible) provider
# points at the local DeepSeek proxy by default. The entrypoint substitutes
# runtime values from env vars so users can override without rebuilding.
RUN mkdir -p /home/agent/.nanobot && cat > /home/agent/.nanobot/config.json.template << 'JSON'
{
  "agents": {
    "defaults": {
      "provider": "custom",
      "model": "__MODEL__"
    }
  },
  "providers": {
    "custom": {
      "api_key": "__API_KEY__",
      "api_base": "__API_BASE__"
    }
  }
}
JSON
RUN chown -R agent:agent /home/agent/.nanobot

# Entrypoint substitutes runtime values into the config and runs the agent.
RUN cat > /usr/local/bin/run-agent << 'SCRIPT'
#!/bin/bash
set -e
PROMPT=$(cat "$PROMPT_FILE")
echo "=== nanobot ==="
echo "Prompt: $PROMPT"
echo "Workspace: $WORKSPACE"
echo ""

# Materialize config from template + env
API_BASE="${OPENAI_BASE_URL:-http://host.docker.internal:7777/openai/v1}"
API_KEY="${OPENAI_API_KEY:-dummy}"
MODEL="${NANOBOT_MODEL:-deepseek-chat}"
sed -e "s|__MODEL__|${MODEL}|g" \
    -e "s|__API_KEY__|${API_KEY}|g" \
    -e "s|__API_BASE__|${API_BASE}|g" \
    /home/agent/.nanobot/config.json.template > /home/agent/.nanobot/config.json

cd "$WORKSPACE"
nanobot agent -m "$PROMPT" 2>&1 || true
echo ""
echo "=== Done ==="
SCRIPT
RUN chmod +x /usr/local/bin/run-agent

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/run-agent"]

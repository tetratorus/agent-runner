FROM agent-runner/base:latest

USER root

# Install Gemini CLI
RUN npm install -g @google/gemini-cli

# Create entrypoint script
RUN cat > /usr/local/bin/run-agent << 'SCRIPT'
#!/bin/bash
set -e
PROMPT=$(cat "$PROMPT_FILE")
echo "=== Gemini CLI ==="
echo "Prompt: $PROMPT"
echo "Workspace: $WORKSPACE"
echo ""
cd "$WORKSPACE"
# Gemini CLI non-interactive mode
# gemini --help shows: gemini <prompt> or gemini --file <file>
gemini "$PROMPT" 2>&1 || true
echo ""
echo "=== Done ==="
SCRIPT
RUN chmod +x /usr/local/bin/run-agent

USER agent
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/run-agent"]
